# ── Version control ──────────────────────────────────────────────────────────────
.git
.gitignore

# ── Python cache ────────────────────────────────────────────────────────────────
__pycache__
*.pyc
*.pyo
*.egg-info
.pytest_cache

# ── Environment & secrets ──────────────────────────────────────────────────────
.env
.venv

# ── Data & local volumes ────────────────────────────────────────────────────────
chroma_data

# ── Test & dev ───────────────────────────────────────────────────────────────────
tests/
.claude/
scripts/

# ── IDE ──────────────────────────────────────────────────────────────────────────
.vscode
.idea

# ── Docker ───────────────────────────────────────────────────────────────────────
docker/
docker-compose.yml

